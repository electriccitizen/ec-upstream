{#
/**
 * @file
 * Theme implementation for the content_list paragraph.
 *
 * Variables set by citizen_custom_preprocess_paragraph__content_list():
 * - content_list_preview_mode: TRUE when paragraph is unsaved (no ID).
 * - content_list_has_results: TRUE when the view returned results.
 * - content_list_view: The rendered view output.
 * - content_type_key: The content type machine name (e.g., "event", "news").
 *
 * @see citizen_custom_preprocess_paragraph__content_list()
 *
 * @ingroup themeable
 */
#}

{% if content_list_preview_mode is defined and content_list_preview_mode %}
  <p><strong>Content list widgets are not available in preview until the node is saved.</strong></p>
{% elseif content_list_has_results %}
  <div class="paragraph paragraph--type--content-list content-{{ content_type_key }}-list">
    {{ content.field_widget_title }}
    {{ content_list_view }}
    {{ content.field_link }}
  </div>
{% endif %}
