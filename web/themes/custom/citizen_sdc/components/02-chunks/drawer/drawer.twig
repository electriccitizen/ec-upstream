{% if toggle_position != 'below' %}
  <button class="drawer-toggle drawer-toggle--{{ toggle_position }} button--clean" aria-controls="drawer-{{ rando }}" aria-expanded="false" data-toggle-open="{{ toggle_open_text|t }}" data-toggle-close="{{ toggle_close_text|t }}">
    <span class="drawer-toggle__text">{{ toggle_open_text|t }}</span>
    <svg class="drawer-toggle__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 6" role="img" aria-hidden="true" focusable="false">
      <path d="M8,1.3l-.9-.9-3.1,3.1L.9.3l-.9.9,4,4,4-4Z" />
    </svg>
  </button>
{% endif %}

<div id="drawer-{{ rando }}" class="drawer-content drawer-content--{{ drawer_style }}" aria-hidden="true">
  {{ drawer }}
</div>

{% if toggle_position == 'below' %}
  <button class="drawer-toggle drawer-toggle--{{ toggle_position }} button--clean" aria-controls="drawer-{{ rando }}" aria-expanded="false" data-toggle-open="{{ toggle_open_text|t }}" data-toggle-close="{{ toggle_close_text|t }}">
    <span class="drawer-toggle__text">{{ toggle_open_text|t }}</span>
    <svg class="drawer-toggle__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 6" role="img" aria-hidden="true" focusable="false">
      <path d="M8,1.3l-.9-.9-3.1,3.1L.9.3l-.9.9,4,4,4-4Z" />
    </svg>
  </button>
{% endif %}
