{% set view_classes = [
  'view',
  'view--' ~ css_name|clean_class,
  display_id ? 'view--' ~ css_name|clean_class ~ '--' ~ display_id|clean_class,
  dom_id ? 'js-view-dom-id-' ~ dom_id,
] %}
{% set view_attr = (attr ?: create_attribute()).addClass(view_classes) %}

<div{{ view_attr }}>
  {{ title_prefix }}
  {{ title }}
  {{ title_suffix }}

  {% if header %}
    <div class="view__header">{{ header }}</div>
  {% endif %}

  {{ exposed }}
  {{ attachment_before }}

  {% if rows %}
    <div class="view__content">{{ rows }}</div>
  {% endif %}

  {% if empty %}
    <div class="view__empty">{{ empty }}</div>
  {% endif %}

  {{ pager }}
  {{ attachment_after }}
  {{ more }}

  {% if footer %}
    <div class="view__footer">{{ footer }}</div>
  {% endif %}

  {{ feed_icons }}
</div>
