{% set teaser_content %}
  {% if date %}
    <div class="node-teaser__date">{{ date|date('F j, Y') }}</div>
  {% endif %}
  {% if summary %}
    {{ summary }}
  {% endif %}
{% endset %}

{{ include('citizen_sdc:node-teaser-base', {
  attr: attr,
  modifier_class: 'news',
  title: title,
  url: url,
  title_attr: title_attr,
  image: image,
  content: teaser_content,
}, with_context = false) }}
