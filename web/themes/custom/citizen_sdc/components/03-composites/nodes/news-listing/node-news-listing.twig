{% set listing_content %}
  {% if date %}
    <div class="node-listing__date">{{ date|date('F j, Y') }}</div>
  {% endif %}
  {% if summary %}
    {{ summary }}
  {% endif %}
{% endset %}

{{ include('citizen_sdc:node-listing-base', {
  attr: attr,
  modifier_class: 'news',
  title: title,
  url: url,
  title_attr: title_attr,
  content: listing_content,
}, with_context = false) }}
