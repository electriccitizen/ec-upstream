{# `content` is intentionally not a declared slot on this SDC — the section
   bundle has no paragraph field of its own. It still arrives here via the
   Drupal template because the layout_paragraphs module injects the layout
   template + nested child paragraphs into the `content` render array during
   preprocess. We pipe it straight through to paragraph-base so the children
   land inside the section wrapper. #}
{# BEM modifier on the paragraph block: either a style variant
   (`paragraph--layout-section--light-grey` / `--light-blue`) or `--backless`
   when no field_style is set. paragraph-base adds the `paragraph` +
   `paragraph--layout-section` classes; this modifier composes alongside. #}
{% set bem_modifier = style_class
  ? 'paragraph--layout-section--' ~ style_class
  : 'paragraph--layout-section--backless' %}
{% set section_attr = (attr ?: create_attribute()).addClass(bem_modifier) %}

{{ include('citizen_sdc:paragraph-base', {
  attr: section_attr,
  modifier_class: 'layout-section',
  animate: 'no',
  content: content,
}, with_context = false) }}
