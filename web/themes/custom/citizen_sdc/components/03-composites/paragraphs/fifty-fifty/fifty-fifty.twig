{% set alignment_modifier = 'paragraph--fifty-fifty--' ~ (alignment|default('left')) %}
{% set fifty_attr = (attr ?: create_attribute()).addClass(alignment_modifier) %}

{# BEM modifier on the media div based on bundle (image, remote-video, …) so
   CSS can scope image-only rules (equal-height stretch, object-fit cover)
   without affecting video media. #}
{% set media_type_class = media_type ? 'paragraph--fifty-fifty__media--' ~ media_type|clean_class : '' %}

{% set fifty_body %}
  <div class="paragraph--fifty-fifty__media{% if media_type_class %} {{ media_type_class }}{% endif %}">
    {{ media }}
  </div>
  <div class="paragraph--fifty-fifty__content">
    <h2 class="paragraph--fifty-fifty__title">{{ title }}</h2>
    {% if text %}
      <div class="paragraph--fifty-fifty__text">
        {{ text }}
      </div>
    {% endif %}
    {% if link %}
      <div class="paragraph--fifty-fifty__actions">
        {{ link }}
      </div>
    {% endif %}
  </div>
{% endset %}

{{ include('citizen_sdc:paragraph-base', {
  attr: fifty_attr,
  modifier_class: 'fifty-fifty',
  animate: 'yes',
  content: fifty_body,
}, with_context = false) }}
