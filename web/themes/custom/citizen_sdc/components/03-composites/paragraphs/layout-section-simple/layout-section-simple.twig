{# `content` is not a declared slot — same rationale as layout-section.twig.
   layout_paragraphs injects the layout + nested children into the `content`
   render array during preprocess; we pipe it through so they land inside
   the section wrapper. #}
{% set section_attr = (attr ?: create_attribute()).addClass('backless') %}

{{ include('citizen_sdc:paragraph-base', {
  attr: section_attr,
  modifier_class: 'layout-section-simple',
  animate: 'no',
  content: content,
}, with_context = false) }}
