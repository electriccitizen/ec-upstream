{% set accordions_body %}
  {% if title %}
    <h2 class="paragraph--accordions__title">{{ title }}</h2>
  {% endif %}
  <div class="paragraph--accordions__items" data-accordions>
    {% for item in items %}
      {% set panel_id = 'accordion-panel-' ~ item.id %}
      <div class="paragraph--accordions__item is-collapsed" data-accordion-item-id="{{ item.id }}">
        <button type="button" class="paragraph--accordions__toggle" aria-controls="{{ panel_id }}" aria-expanded="false">
          <span class="paragraph--accordions__label">{{ item.header }}</span>
          <span class="paragraph--accordions__icon paragraph--accordions__icon--plus">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="16"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
          </span>
          <span class="paragraph--accordions__icon paragraph--accordions__icon--minus">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
              <circle cx="12" cy="12" r="10"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
          </span>
        </button>
        <div class="paragraph--accordions__panel" id="{{ panel_id }}" aria-hidden="true" inert>
          <div class="paragraph--accordions__body">
            {{ item.body }}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endset %}

{{ include('citizen_sdc:paragraph-base', {
  attr: attr,
  modifier_class: 'accordions',
  animate: 'no',
  content: accordions_body,
}, with_context = false) }}
