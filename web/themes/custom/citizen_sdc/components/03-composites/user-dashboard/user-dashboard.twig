{% set dashboard_attr = (attr ?: create_attribute()).addClass('user-dashboard') %}

<article{{ dashboard_attr }}>
  {% if image %}
    <div class="user-dashboard__media">{{ image }}</div>
  {% endif %}

  <div class="user-dashboard__info">
    <h1 class="user-dashboard__name">{{ name }}</h1>

    <div class="user-dashboard__meta">
      <span class="user-dashboard__meta-label">Username:</span>
      <span class="user-dashboard__meta-value">{{ username }}</span>
    </div>

    {% if roles %}
      <div class="user-dashboard__meta user-dashboard__meta--roles">
        <span class="user-dashboard__meta-label">Roles:</span>
        <span class="user-dashboard__meta-value">{{ roles }}</span>
      </div>
    {% endif %}

    {% if account_actions %}
      <nav class="user-dashboard__account-actions" aria-label="Account actions">
        <ul>
          {% for action in account_actions %}
            <li>
              <a href="{{ action.url }}">{{ action.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    {% if task_actions %}
      <nav class="user-dashboard__task-actions" aria-label="Editor tasks">
        <ul>
          {% for action in task_actions %}
            <li>
              <a href="{{ action.url }}" class="ec-button">{{ action.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    {% if masquerade %}
      <div class="user-dashboard__masquerade">{{ masquerade }}</div>
    {% endif %}
  </div>
</article>
