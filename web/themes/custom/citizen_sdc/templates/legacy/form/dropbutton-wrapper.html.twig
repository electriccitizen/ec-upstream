{#
/**
 * @file
 * Theme override for a dropbutton wrapper.
 *
 * Available variables:
 * - children: Contains the child elements of the dropbutton menu.
 *
 * @see template_preprocess()
 */
#}
{% if children %}
  <div class="dropbutton__wrapper">
    <div class="dropbutton__widget">
      {{- children -}}
    </div>
  </div>
{% endif %}
