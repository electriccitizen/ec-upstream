{#
/**
 * @file
 * Default search-result template. Delegates to node-search-result-base.
 * Content types with their own search-result SDC (node-[type]-search-result)
 * ship their own Drupal template override at
 * `node--[type]--search-result.html.twig`.
 *
 * The meta description comes from `field_meta_description`, rendered by the
 * per-bundle `search_result` view display. The site-search highlighting JS
 * targets the `.node-search-result__meta-description` selector that the SDC
 * wraps around it.
 */
#}
{{ include('citizen_sdc:node-search-result-base', {
  attr: attributes,
  modifier_class: node.type.0.target_id|clean_class,
  title: label.0['#context'].value,
  url: url,
  title_attr: title_attributes,
  content_type_label: node.type.entity.label,
  meta_description: content.field_meta_description,
}, with_context = false) }}
