{#
/**
 * @file
 * News default/full view — delegates to node-news-default SDC. Mirrors the
 * Layout Builder section-wrapping logic from the generic node.html.twig so
 * sections render inside `.node-content__section` wrappers.
 */
#}
{% set node_content %}
  {%- if content._layout_builder -%}
    {% if content._layout_builder.0 %}
      {%- for key, layoutSection in content._layout_builder -%}
        {% if key|first != '#' %}
          <section id="node-section-{{ loop.index }}" class="node-content__section">
            {{- layoutSection -}}
          </section>
        {% endif %}
      {%- endfor -%}
    {% else %}
      {{- content -}}
    {% endif %}
  {%- else -%}
    {{- content -}}
  {%- endif -%}
{% endset %}

{{ include('citizen_sdc:node-news-default', {
  attr: attributes,
  title_prefix: title_prefix,
  title_suffix: title_suffix,
  content: node_content,
}, with_context = false) }}
