{#
/**
 * @file
 * Layout template for the `twocol_sideleft` layout plugin. Delegates to
 * the citizen_sdc:twocol-sideleft SDC.
 *
 * Available variables:
 * - content: The content for this layout.
 * - attributes: HTML attributes for the layout <div>.
 * - region_attributes: HTML attributes for each region wrapper.
 *
 * @ingroup themeable
 */
#}
{% if content %}
  {{ include('citizen_sdc:twocol-sideleft', {
    attr: attributes,
    first_attr: region_attributes.first,
    content_attr: region_attributes.content,
    first: content.first,
    content: content.content,
  }, with_context = false) }}
{% endif %}
