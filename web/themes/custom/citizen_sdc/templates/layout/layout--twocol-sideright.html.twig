{#
/**
 * @file
 * Layout template for the `twocol_sideright` layout plugin. Delegates to
 * the citizen_sdc:twocol-sideright SDC.
 *
 * Available variables:
 * - content: The content for this layout.
 * - attributes: HTML attributes for the layout <div>.
 * - region_attributes: HTML attributes for each region wrapper.
 *
 * @ingroup themeable
 */
#}
{% if content %}
  {{ include('citizen_sdc:twocol-sideright', {
    attr: attributes,
    content_attr: region_attributes.content,
    second_attr: region_attributes.second,
    content: content.content,
    second: content.second,
  }, with_context = false) }}
{% endif %}
