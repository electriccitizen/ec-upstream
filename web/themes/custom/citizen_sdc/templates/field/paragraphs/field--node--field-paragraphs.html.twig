{#
/**
 * @file
 * Paragraph field — deliberately does NOT extend `field.html.twig`. We want
 * a minimal wrapper (`<div class="field-paragraphs">`) with each item
 * rendered raw, so layout-section paragraph wrappers land as direct children
 * of `.field-paragraphs` and their `+` sibling selectors (same-style seam
 * collapse) work correctly.
 */
#}
<div class="field-paragraphs">
  {%- for item in items -%}
    {{- item.content -}}
  {%- endfor -%}
</div>
